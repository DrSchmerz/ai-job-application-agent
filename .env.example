# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real keys.

# --- LLM providers (at least one recommended; "local" fallback needs none) ---
OPENAI_API_KEY=sk-your-openai-key-here
GROQ_API_KEY=your-groq-key-here
GOOGLE_API_KEY=your-google-gemini-key-here

# Which provider to prefer: local | groq | google | openai | auto
DEFAULT_LLM_PROVIDER=auto

# --- Gmail integration (optional; for email tracking) ---
# Use a Google "App Password", NOT your normal password.
GMAIL_EMAIL=you@example.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# --- Database (optional) ---
# Point the app at a different SQLite file, e.g. a demo DB.
# APP_DB_PATH=applications.db
